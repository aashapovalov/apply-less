# === SHARED ===
NODE_ENV=development
LOG_LEVEL=debug

# === PostgreSQL ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/applyless
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=applyless

# === Firebase (for API and Web) ===
# API (Admin SDK)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Web (Client SDK)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id

# === Python ML Service ===
ML_SERVICE_URL=http://localhost:5001
ML_SERVICE_API_KEY=

# === Open-source Model APIs ===
# Example: Hugging Face Inference API (free tier)
HF_API_KEY=
EMBEDDING_MODEL=
LLM_MODEL=


# === Startup Nation Central (Web Scraping) ===
SNC_BASE_URL=https://finder.startupnationcentral.org
SNC_AUTH_TOKEN=your-snc-token-jwt
SNC_REFRESH_TOKEN=your-refresh-token-uuid
SNC_USER_ID=your-user-id
# Full cookie string (optional, for session simulation)
SNC_COOKIES=

# === API Server ===
API_PORT=3001
API_BASE_URL=http://localhost:3001

# === Web Frontend ===
VITE_API_BASE_URL=http://localhost:3001

# === Ingestion Worker ===
INGESTION_CRON_SCHEDULE=0 2 * * * # 2 AM daily
INGESTION_BATCH_SIZE=50
INGESTION_MAX_RETRIES=3
INGESTION_RETRY_DELAY_MS=5000